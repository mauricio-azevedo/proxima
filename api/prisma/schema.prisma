generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  REGISTERED
  PLACEHOLDER
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PickupGameVisibility {
  PRIVATE
  PUBLIC
}

enum PickupGameUserRole {
  MEMBER
  ADMIN
}

enum GameDayStatus {
  SCHEDULED
  WAITING_FOR_PLAYERS
  PLAYING
  FINISHED
  CANCELLED
}

enum MatchStatus {
  RUNNING
  FINISHED
  CANCELLED
}

enum MatchSide {
  A
  B
}

model User {
  id           String     @id @default(uuid())
  firstName    String?    @map("first_name")
  lastName     String?    @map("last_name")
  nickname     String
  email        String?    @unique
  passwordHash String?    @map("password_hash")
  status       UserStatus @default(PLACEHOLDER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdPickupGames PickupGame[]     @relation("PickupGameCreator")
  pickupGameUsers    PickupGameUser[]
  dayListEntries     DayListEntry[]
  queueEntries       QueueEntry[]
  matchPlayers       MatchPlayer[]

  scoredGoals  GoalEvent[] @relation("GoalScorer")
  assistedGoals GoalEvent[] @relation("GoalAssistant")
  createdGoals GoalEvent[] @relation("GoalCreator")
  updatedGoals GoalEvent[] @relation("GoalUpdater")
  deletedGoals GoalEvent[] @relation("GoalDeleter")

  @@map("users")
}

model PickupGame {
  id                  String               @id @default(uuid())
  name                String
  locationName        String?              @map("location_name")
  weekday             Weekday
  startTime           String               @map("start_time")
  defaultTeamSize     Int                  @default(5) @map("default_team_size")
  visibility          PickupGameVisibility @default(PRIVATE)
  createdByUserId     String               @map("created_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy User @relation("PickupGameCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  users PickupGameUser[]
  days  GameDay[]

  @@index([createdByUserId])
  @@index([visibility])
  @@index([weekday, startTime])
  @@map("pickup_games")
}

model PickupGameUser {
  id           String             @id @default(uuid())
  pickupGameId String             @map("pickup_game_id")
  userId       String             @map("user_id")
  role         PickupGameUserRole @default(MEMBER)

  createdAt DateTime @default(now()) @map("created_at")

  pickupGame PickupGame @relation(fields: [pickupGameId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pickupGameId, userId])
  @@index([userId])
  @@index([pickupGameId, role])
  @@map("pickup_game_users")
}

model GameDay {
  id           String        @id @default(uuid())
  pickupGameId String        @map("pickup_game_id")
  date         DateTime      @db.Date
  status       GameDayStatus @default(SCHEDULED)
  teamSize     Int           @map("team_size")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pickupGame PickupGame @relation(fields: [pickupGameId], references: [id], onDelete: Cascade)

  listEntries  DayListEntry[]
  queueEntries QueueEntry[]
  matches      Match[]

  @@unique([pickupGameId, date])
  @@index([status])
  @@index([date])
  @@map("game_days")
}

model DayListEntry {
  id        String    @id @default(uuid())
  gameDayId String    @map("game_day_id")
  userId    String    @map("user_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  removedAt DateTime? @map("removed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  gameDay GameDay @relation(fields: [gameDayId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  queueEntries QueueEntry[]

  @@index([gameDayId, userId])
  @@index([userId])
  @@index([removedAt])
  @@map("day_list_entries")
}

model QueueEntry {
  id             String    @id @default(uuid())
  gameDayId      String    @map("game_day_id")
  userId         String    @map("user_id")
  dayListEntryId String?   @map("day_list_entry_id")
  arrivedAt      DateTime  @default(now()) @map("arrived_at")
  currentPosition Int      @map("current_position")
  removedAt      DateTime? @map("removed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  gameDay      GameDay       @relation(fields: [gameDayId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  dayListEntry DayListEntry? @relation(fields: [dayListEntryId], references: [id], onDelete: SetNull)

  @@index([gameDayId, currentPosition])
  @@index([gameDayId, userId])
  @@index([userId])
  @@index([removedAt])
  @@map("queue_entries")
}

model Match {
  id        String      @id @default(uuid())
  gameDayId String      @map("game_day_id")
  number    Int
  teamSize  Int         @map("team_size")
  status    MatchStatus @default(RUNNING)
  startedAt DateTime    @default(now()) @map("started_at")
  endedAt   DateTime?   @map("ended_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  gameDay GameDay @relation(fields: [gameDayId], references: [id], onDelete: Cascade)

  players MatchPlayer[]
  goals   GoalEvent[]

  @@unique([gameDayId, number])
  @@index([gameDayId, status])
  @@index([startedAt])
  @@map("matches")
}

model MatchPlayer {
  id      String    @id @default(uuid())
  matchId String    @map("match_id")
  userId  String    @map("user_id")
  side    MatchSide
  slot    Int

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, userId])
  @@unique([matchId, side, slot])
  @@index([matchId, side])
  @@index([userId])
  @@map("match_players")
}

model GoalEvent {
  id             String    @id @default(uuid())
  matchId        String    @map("match_id")
  side           MatchSide
  scorerUserId   String    @map("scorer_user_id")
  assistUserId   String?   @map("assist_user_id")
  minute         Int?
  occurredAt     DateTime? @map("occurred_at")
  createdByUserId String   @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  deletedAt      DateTime? @map("deleted_at")
  deletedByUserId String?  @map("deleted_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorer    User  @relation("GoalScorer", fields: [scorerUserId], references: [id], onDelete: Restrict)
  assist    User? @relation("GoalAssistant", fields: [assistUserId], references: [id], onDelete: SetNull)
  createdBy User  @relation("GoalCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy User? @relation("GoalUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedBy User? @relation("GoalDeleter", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, deletedAt])
  @@index([scorerUserId])
  @@index([assistUserId])
  @@index([createdByUserId])
  @@index([deletedAt])
  @@map("goal_events")
}
