# Copy this file to `.env` and fill in real values for your machine.
#   cp .env.example .env
#
# Every variable here is validated at startup by src/env.ts (via Zod). If a
# required variable is missing or malformed, the app refuses to boot with a
# clear error instead of failing mysteriously later.

# PostgreSQL connection string.
# The default below matches docker-compose.yml (run `docker compose up -d`).
DATABASE_URL="postgresql://proxima:proxima@localhost:5434/proxima?schema=public"
