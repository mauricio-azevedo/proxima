{
  "name": "proxima",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "web": "npm run start -w web",
    "api": "npm run start:dev -w api",
    "dev": "concurrently \"npm run web\" \"npm run api\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauricio-azevedo/proxima.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mauricio-azevedo/proxima/issues"
  },
  "homepage": "https://github.com/mauricio-azevedo/proxima#readme",
  "description": "",
  "devDependencies": {
    "concurrently": "^10.0.1",
    "prettier": "^3.8.1"
  }
}
